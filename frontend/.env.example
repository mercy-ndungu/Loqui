# Client API path — always /api (same-origin). Do NOT set this to the Render URL.
VITE_API_URL=/api

# Vite dev proxy target (local backend only — not used on Vercel).
VITE_BACKEND_URL=http://localhost:8000

# Auth is handled by the FastAPI backend + httpOnly cookies.
# You do NOT need VITE_SUPABASE_* in the frontend.
